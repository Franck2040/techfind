# =============================================================================
# .env.example — Modèle de configuration (À COPIER en `.env`)
# -----------------------------------------------------------------------------
# Copiez ce fichier :  cp .env.example .env   (puis remplissez les valeurs)
# Le fichier .env réel n'est JAMAIS versionné (voir .gitignore) : il contient
# vos secrets. Ne mettez jamais de secret directement dans le code.
# =============================================================================

# --- Base de données ---------------------------------------------------------
# Par défaut : SQLite (fichier local, zéro configuration).
# Pour la PRODUCTION, remplacez par une URL PostgreSQL, ex :
#   DATABASE_URL="postgresql://user:pass@host:5432/techfind"
# (et changez provider = "postgresql" dans prisma/schema.prisma)
DATABASE_URL="file:./dev.db"

# --- Connexions sociales (OPTIONNEL) -----------------------------------------
# Laissez vide pour masquer/désactiver les boutons Google/Facebook.
# Renseignez pour les activer (créez les identifiants côté Google/Facebook).
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
FACEBOOK_CLIENT_ID=""
FACEBOOK_CLIENT_SECRET=""

# --- Paiement en ligne Stripe (OPTIONNEL) ------------------------------------
# Laissez vide : seul le "paiement à la livraison" sera proposé.
# Renseignez vos clés Stripe (mode test dispo) pour activer la carte bancaire.
STRIPE_SECRET_KEY=""
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""

# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files — on ignore les secrets MAIS on garde .env.example comme modèle
.env
.env.*
!.env.example

# base de données locale (Prisma SQLite) — ne jamais committer
*.db
*.db-journal
/prisma/dev.db*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
